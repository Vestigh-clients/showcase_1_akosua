# Frontend environment variables for a new client deployment.
# Copy to `.env` and replace placeholder values.

# Supabase
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=

# StyleSyncs API (Vestigh try-on)
VITE_STYLESYNC_API_KEY=
VITE_STYLESYNC_API_URL=

# Paystack
# Mode is set in `src/config/store.config.ts`:
# "subaccount" for Tier 1, "own_account" for Tier 2

# Public key (safe for frontend)
# Tier 1: Vestigh's Paystack public key
# Tier 2: Client's own Paystack public key
VITE_PAYSTACK_PUBLIC_KEY=pk_test_e5b43c1fe67f99e89196eb4a16ad66f1ba87717a

# Subaccount code - Tier 1 only
# Leave empty for Tier 2
# Format: ACCT_xxxxxxxxxxxxxxxxx
VITE_PAYSTACK_SUBACCOUNT_CODE=

# Secret key - NEVER put in frontend `.env`
# Add directly to Supabase edge function secrets as: PAYSTACK_SECRET_KEY
# Tier 1: Vestigh's Paystack secret key (Vestigh manages this)
# Tier 2: Client's own Paystack secret key

# Store identity (optional; can be set directly in `src/config/store.config.ts`)
VITE_STORE_NAME=

# Optional legacy aliases (supported by current store config fallback)
# VITE_STYLESYNCS_API_KEY=
# VITE_STYLESYNCS_BASE_URL=
